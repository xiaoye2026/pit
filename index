<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PIT: Journal of Professional Inutile Training</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root { --main-color: #1a1a1a; --bg-color: #fdfdfb; --accent-red: #d32f2f; }
        body { font-family: "Times New Roman", Times, "SimSun", serif; background-color: var(--bg-color); color: var(--main-color); max-width: 1100px; margin: 0 auto; padding: 20px; line-height: 1.6; font-size: 14px; }
        
        /* 刊头 */
        .header { text-align: center; border-bottom: 4px double #000; padding-bottom: 15px; margin-bottom: 25px; }
        .header h1 { font-size: 2.8rem; margin: 0; font-weight: 900; letter-spacing: -1px; }
        .issn { font-size: 0.8rem; letter-spacing: 2px; color: #555; }

        /* Slogan */
        .slogan-container { text-align: center; margin: 30px 0; padding: 15px; border: 1px solid #eee; }
        .slogan-en { font-size: 1.4rem; font-weight: 800; margin-bottom: 5px; }
        .slogan-cn { font-size: 1.6rem; font-weight: 900; color: #000; margin: 0; }

        /* 布局 */
        .layout { display: flex; flex-wrap: wrap; gap: 30px; }
        .main-col { flex: 2; min-width: 350px; }
        .side-col { flex: 1.1; min-width: 300px; border-left: 1px solid #ddd; padding-left: 25px; }

        .section-title { background: #000; color: #fff; padding: 6px 12px; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center; }
        .section-title h2 { margin: 0; font-size: 1rem; letter-spacing: 1px; }

        /* 文献卡片 */
        .paper-item { margin-bottom: 25px; border-bottom: 1px solid #eee; padding-bottom: 15px; position: relative; }
        .paper-title { font-size: 1.2rem; font-weight: bold; color: #000; text-decoration: none; display: block; margin-bottom: 5px; cursor: pointer; }
        .paper-title:hover { color: var(--accent-red); }
        .paper-meta { font-size: 0.8rem; color: #888; margin-bottom: 8px; }
        .paper-abstract { font-size: 0.9rem; background: #f9f9f7; padding: 10px; border-left: 3px solid #000; margin-bottom: 10px; }
        
        /* 文献交互区 */
        .paper-footer { display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; }
        .paper-btns { display: flex; gap: 15px; align-items: center; }
        .like-btn { cursor: pointer; color: #555; border: 1px solid #ccc; padding: 1px 8px; border-radius: 3px; background: #fff; transition: 0.2s; }
        .like-btn:hover { border-color: var(--accent-red); color: var(--accent-red); }
        .fulltext-link { color: var(--accent-red); text-decoration: none; font-weight: bold; cursor: pointer; }

        /* 分页 */
        .pagination { display: flex; justify-content: center; gap: 15px; margin: 20px 0; align-items: center; font-weight: bold; }
        .page-nav { background: #000; color: #fff; border: none; padding: 5px 15px; cursor: pointer; font-size: 0.8rem; }
        .page-nav:disabled { background: #ccc; cursor: not-allowed; }

        /* 弹窗：右上角关闭 */
        dialog { border: 3px solid #000; padding: 25px; width: 90%; max-width: 550px; position: relative; }
        .close-x { position: absolute; top: 10px; right: 15px; font-size: 1.5rem; cursor: pointer; font-weight: bold; line-height: 1; color: #999; }
        .close-x:hover { color: #000; }

        /* 通用 */
        button { background: #000; color: #fff; border: none; padding: 8px 16px; cursor: pointer; font-weight: bold; font-family: inherit; }
        input, textarea { width: 100%; padding: 8px; margin-bottom: 10px; border: 1px solid #ccc; box-sizing: border-box; }
        .pi-card { border: 1px solid #ddd; padding: 10px; margin-bottom: 10px; background: #fff; }
    </style>
</head>
<body>

    <div class="header">
        <h1>PIT: Journal of Professional Inutile Training</h1>
        <div class="issn">ISSN 2026-0250 | 坑底直连数据库</div>
    </div>

    <div class="slogan-container">
        <p class="slogan-en">Focusing on Research That Changes Absolutely Nothing</p>
        <p class="slogan-cn">既然深陷坑底，不如挖得更有创意——极致的无用之美。</p>
    </div>

    <div class="layout">
        <div class="main-col">
            <div class="section-title">
                <h2>Current Issue / 最新文献</h2>
                <button onclick="document.getElementById('postModal').showModal()" style="font-size: 0.75rem;">我要投稿</button>
            </div>
            <div id="papers-list">📡 文献调取中...</div>
            <div class="pagination" id="page-controls"></div>
        </div>

        <div class="side-col">
            <div class="section-title">
                <h2>Pit Index / 天坑指数</h2>
                <button onclick="document.getElementById('majorModal').showModal()" style="font-size: 0.7rem;">申报</button>
            </div>
            <div id="pi-list">📡 指数刷新中...</div>
        </div>
    </div>

    <dialog id="postModal">
        <span class="close-x" onclick="this.closest('dialog').close()">&times;</span>
        <h3 style="margin-top:0;">Submit to PIT</h3>
        <input type="text" id="p-title" placeholder="文章标题">
        <input type="text" id="p-author" placeholder="作者 (或匿名)">
        <textarea id="p-abstract" rows="2" placeholder="简短摘要"></textarea>
        <textarea id="p-content" rows="6" placeholder="正文内容..."></textarea>
        <button onclick="submitPaper()" style="width:100%;">立即发表</button>
    </dialog>

    <dialog id="majorModal">
        <span class="close-x" onclick="this.closest('dialog').close()">&times;</span>
        <h3 style="margin-top:0;">申报新天坑</h3>
        <input type="text" id="m-name" placeholder="专业名称">
        <textarea id="m-desc" placeholder="简短描述"></textarea>
        <button onclick="addNewMajor()" style="width:100%;">确认</button>
    </dialog>

    <script>
        const supabaseUrl = 'https://lbuhtjezlkirkxbfgwvt.supabase.co';
        const p1 = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.';
        const p2 = 'eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxidWh0amV6bGtpcmt4YmZnd3Z0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI1Mzk0OTksImV4cCI6MjA4ODExNTQ5OX0.dBP_u7PXyy9D_mCYGYDkDzvOArDBcQ6Qf8FO0wdO5lg';
        const _supabase = supabase.createClient(supabaseUrl, p1 + p2);

        let curPage = 1;
        const pageSize = 10;

        window.onload = () => { fetchPapers(); fetchPI(); };

        // --- 核心：文献加载与分页 ---
        async function fetchPapers() {
            const start = (curPage - 1) * pageSize;
            const end = start + pageSize - 1;

            const { data, count } = await _supabase.from('pit_papers')
                .select('*', { count: 'exact' })
                .order('created_at', { ascending: false })
                .range(start, end);

            const list = document.getElementById('papers-list');
            list.innerHTML = data?.map(p => `
                <div class="paper-item">
                    <span class="paper-title" onclick="viewPaper('${p.id}')">${p.title}</span>
                    <div class="paper-meta">Author: ${p.author || '匿名受害者'} | Date: ${new Date(p.created_at).toLocaleDateString()}</div>
                    <div class="paper-abstract"><strong>Abstract:</strong> ${p.abstract}</div>
                    <div class="paper-footer">
                        <div class="paper-btns">
                            <span class="like-btn" onclick="handleLike('${p.id}', ${p.likes || 0})">👍 共鸣 ${p.likes || 0}</span>
                        </div>
                        <a class="fulltext-link" onclick="viewPaper('${p.id}')">VIEW FULL TEXT &rarr;</a>
                    </div>
                </div>
            `).join('') || '尚无学术产出。';

            renderPageBtns(count);
        }

        function renderPageBtns(total) {
            const totalPages = Math.ceil(total / pageSize);
            const ctrl = document.getElementById('page-controls');
            ctrl.innerHTML = `
                <button class="page-nav" ${curPage === 1 ? 'disabled' : ''} onclick="turnPage(-1)">PREV</button>
                <span style="font-size:0.85rem">Page ${curPage} / ${totalPages || 1}</span>
                <button class="page-nav" ${curPage >= totalPages ? 'disabled' : ''} onclick="turnPage(1)">NEXT</button>
            `;
        }

        function turnPage(dir) {
            curPage += dir;
            fetchPapers();
            window.scrollTo(0, 400);
        }

        // --- 交互逻辑 ---
        async function handleLike(id, cur) {
            await _supabase.from('pit_papers').update({ likes: cur + 1 }).eq('id', id);
            fetchPapers();
        }

        function viewPaper(id) {
            alert("正在从坑底调取全文档案... (ID: " + id + ")");
        }

        async function submitPaper() {
            const title = document.getElementById('p-title').value;
            const author = document.getElementById('p-author').value;
            const abstract = document.getElementById('p-abstract').value;
            const content = document.getElementById('p-content').value;
            if(!title) return alert("请填写标题");
            await _supabase.from('pit_papers').insert([{ title, author, abstract, content, likes: 0 }]);
            location.reload();
        }

        // --- 天坑指数 ---
        async function fetchPI() {
            const { data } = await _supabase.from('pit_forum').select('*').order('count', { ascending: true });
            const list = document.getElementById('pi-list');
            list.innerHTML = data?.map(f => `
                <div class="pi-card">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <strong>${f.name}</strong>
                        <span style="font-size:1.2rem; color:var(--accent-red); font-weight:900;">${f.count}</span>
                    </div>
                    <p style="font-size:0.8rem; color:#777; margin:5px 0 0 0;">${f.description || ''}</p>
                </div>
            `).join('') || '暂无数据';
        }

        async function addNewMajor() {
            const name = document.getElementById('m-name').value;
            const description = document.getElementById('m-desc').value;
            await _supabase.from('pit_forum').insert([{ name, description, count: 0 }]);
            location.reload();
        }
    </script>
</body>
</html>
