<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PIT: Journal of Professional Inutile Training</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root { --main-color: #1c1c1c; --bg-color: #f4f4f2; --accent-red: #b22222; }
        body { font-family: "Times New Roman", Times, "Songti SC", serif; background-color: var(--bg-color); color: var(--main-color); max-width: 1300px; margin: 0 auto; padding: 30px; line-height: 1.8; font-size: 1.1rem; }
        
        /* Header & Slogan */
        .header { text-align: center; border-bottom: 6px double #000; padding-bottom: 20px; margin-bottom: 40px; }
        .header h1 { font-size: 3.5rem; margin: 0; font-weight: 900; }
        .slogan-box { text-align: center; margin: 40px 0; padding: 30px; border: 1px solid #ddd; background: #fff; }
        .slogan-en { font-size: 1.8rem; font-weight: 800; display: block; }
        .slogan-cn { font-size: 2.4rem; font-weight: 900; margin-top: 10px; display: block; }

        /* Layout */
        .layout { display: flex; flex-wrap: wrap; gap: 40px; }
        .main-col { flex: 2; min-width: 400px; }
        .side-col { flex: 1.2; min-width: 350px; border-left: 3px solid #000; padding-left: 30px; }

        .section-title { background: #000; color: #fff; padding: 12px 20px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; }

        /* 文献卡片优化 */
        .paper-item { background: #fff; border: 1px solid #000; padding: 25px; margin-bottom: 20px; position: relative; }
        .paper-title { font-size: 1.5rem; font-weight: 800; color: #000; text-decoration: none; display: block; margin-bottom: 10px; }
        .paper-abstract { font-size: 1.05rem; background: #f9f9f9; padding: 15px; border-left: 5px solid #000; margin-bottom: 15px; }
        .paper-footer { display: flex; justify-content: space-between; align-items: center; font-size: 0.9rem; }
        .paper-actions { display: flex; gap: 20px; align-items: center; }
        .action-link { color: var(--accent-red); text-decoration: none; font-weight: bold; cursor: pointer; }
        .like-btn { cursor: pointer; border: 1px solid #ddd; padding: 2px 10px; background: #fff; border-radius: 4px; }
        .like-btn:hover { background: #eee; }

        /* 分页控制 */
        .pagination { display: flex; justify-content: center; gap: 20px; margin-top: 30px; align-items: center; }
        .page-btn { background: #000; color: #fff; padding: 8px 20px; border: none; cursor: pointer; font-weight: bold; }
        .page-btn:disabled { background: #ccc; cursor: not-allowed; }

        /* PI Index 卡片 */
        .pi-card { background: #fff; border: 2px solid #000; padding: 15px; margin-bottom: 15px; }
        .pi-score { font-size: 1.8rem; font-weight: 950; color: var(--accent-red); }

        /* 弹窗优化：右上角关闭 */
        dialog { border: 5px solid #000; width: 90%; max-width: 650px; padding: 40px; position: relative; }
        .close-dialog { position: absolute; top: 15px; right: 20px; font-size: 2rem; cursor: pointer; font-weight: bold; line-height: 1; }
        .close-dialog:hover { color: var(--accent-red); }

        /* 通用按钮 */
        button { background: #000; color: #fff; border: none; padding: 10px 20px; cursor: pointer; font-weight: bold; }
        input, textarea { width: 100%; padding: 12px; border: 2px solid #000; margin-bottom: 15px; box-sizing: border-box; font-size: 1rem; }
    </style>
</head>
<body>

    <div class="header">
        <h1>PIT: Journal of Professional Inutile Training</h1>
        <p>EST. 2026 | ISSN: 0000-0250 | 坑底直连</p>
    </div>

    <div class="slogan-box">
        <span class="slogan-en">Focusing on Research That Changes Absolutely Nothing</span>
        <span class="slogan-cn">既然深陷坑底，不如挖得更有创意——极致的无用之美。</span>
    </div>

    <div class="layout">
        <div class="main-col">
            <div class="section-title">
                <h2 style="margin:0;">Current Issue / 最新文献</h2>
                <button onclick="document.getElementById('submitModal').showModal()">我要投稿</button>
            </div>
            <div id="papers-container">加载中...</div>
            <div class="pagination" id="page-controls">
                </div>
        </div>

        <div class="side-col">
            <div class="section-title">
                <h2 style="margin:0;">Pit Index / 天坑指数</h2>
                <button onclick="document.getElementById('majorModal').showModal()" style="font-size:0.8rem">申报</button>
            </div>
            <div id="pi-container">同步中...</div>
        </div>
    </div>

    <dialog id="submitModal">
        <span class="close-dialog" onclick="this.closest('dialog').close()">&times;</span>
        <h3>Submit to PIT (免审直发)</h3>
        <input type="text" id="p-title" placeholder="论文标题">
        <input type="text" id="p-author" placeholder="作者 (或填：匿名受害者)">
        <textarea id="p-abstract" rows="2" placeholder="简短摘要"></textarea>
        <textarea id="p-content" rows="6" placeholder="正文内容"></textarea>
        <button onclick="submitPaper()" style="width:100%; font-size:1.2rem;">立即发表</button>
    </dialog>

    <dialog id="majorModal">
        <span class="close-dialog" onclick="this.closest('dialog').close()">&times;</span>
        <h3>申报新天坑</h3>
        <input type="text" id="m-name" placeholder="专业名称">
        <textarea id="m-desc" placeholder="简短描述"></textarea>
        <button onclick="addNewMajor()" style="width:100%;">确认</button>
    </dialog>

    <script>
        const supabaseUrl = 'https://lbuhtjezlkirkxbfgwvt.supabase.co';
        const p1 = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.';
        const p2 = 'eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxidWh0amV6bGtpcmt4YmZnd3Z0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI1Mzk0OTksImV4cCI6MjA4ODExNTQ5OX0.dBP_u7PXyy9D_mCYGYDkDzvOArDBcQ6Qf8FO0wdO5lg';
        const _supabase = supabase.createClient(supabaseUrl, p1 + p2);

        let currentPage = 1;
        const pageSize = 10;

        window.onload = () => { fetchPapers(); fetchPI(); };

        // --- 文献逻辑 (包含分页、点赞、详情链接) ---
        async function fetchPapers() {
            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize - 1;

            const { data, count } = await _supabase.from('pit_papers')
                .select('*', { count: 'exact' })
                .order('created_at', { ascending: false })
                .range(start, end);

            const container = document.getElementById('papers-container');
            container.innerHTML = data?.map(p => `
                <div class="paper-item">
                    <span class="paper-title">${p.title}</span>
                    <div class="paper-abstract">${p.abstract}</div>
                    <div class="paper-footer">
                        <span>Author: ${p.author}</span>
                        <div class="paper-actions">
                            <span class="like-btn" onclick="likePaper('${p.id}', ${p.likes || 0})">👍 共鸣 (${p.likes || 0})</span>
                            <a class="action-link" onclick="viewFullText('${p.id}')">查看全文 &rarr;</a>
                        </div>
                    </div>
                </div>
            `).join('') || '暂无文献';

            renderPagination(count);
        }

        function renderPagination(total) {
            const totalPages = Math.ceil(total / pageSize);
            const controls = document.getElementById('page-controls');
            controls.innerHTML = `
                <button class="page-btn" ${currentPage === 1 ? 'disabled' : ''} onclick="changePage(-1)">PREV</button>
                <span>Page ${currentPage} of ${totalPages || 1}</span>
                <button class="page-btn" ${currentPage >= totalPages ? 'disabled' : ''} onclick="changePage(1)">NEXT</button>
            `;
        }

        function changePage(dir) {
            currentPage += dir;
            fetchPapers();
            window.scrollTo(0, 500);
        }

        async function likePaper(id, cur) {
            await _supabase.from('pit_papers').update({ likes: cur + 1 }).eq('id', id);
            fetchPapers(); // 局部刷新
        }

        function viewFullText(id) {
            // 这里可以弹窗显示正文，或者跳转。我们先用弹窗演示：
            alert("正在进入学术深渊读取全文... (提示：这里之后可以做成详情页弹窗)");
        }

        // --- 提交逻辑 ---
        async function submitPaper() {
            const title = document.getElementById('p-title').value;
            const author = document.getElementById('p-author').value || '匿名受害者';
            const abstract = document.getElementById('p-abstract').value;
            const content = document.getElementById('p-content').value;
            if(!title) return alert("标题不能为空");
            await _supabase.from('pit_papers').insert([{ title, author, abstract, content, likes: 0 }]);
            location.reload();
        }

        // --- 天坑指数逻辑 ---
        async function fetchPI() {
            const { data } = await _supabase.from('pit_forum').select('*').order('count', { ascending: true });
            const container = document.getElementById('pi-container');
            container.innerHTML = data?.map(f => `
                <div class="pi-card">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <strong>${f.name}</strong>
                        <span class="pi-score">${f.count}</span>
                    </div>
                    <p style="font-size:0.9rem; color:#666; margin:5px 0;">${f.description || ''}</p>
                </div>
            `).join('') || '暂无数据';
        }

        async function addNewMajor() {
            const name = document.getElementById('m-name').value;
            const description = document.getElementById('m-desc').value;
            await _supabase.from('pit_forum').insert([{ name, description, count: 0 }]);
            location.reload();
        }
    </script>
</body>
</html>
